# AI Teacher Studio — Production Environment Configuration
# ===============================================================
# Copy this file to .env and fill in your production values
# IMPORTANT: Never commit .env to version control!
# ===============================================================

# ────────────────────────────────────────────────────────────────
# Database Configuration
# ────────────────────────────────────────────────────────────────
DATABASE_PASSWORD=your_production_database_password_here

# ────────────────────────────────────────────────────────────────
# Redis Configuration
# ────────────────────────────────────────────────────────────────
REDIS_PASSWORD=your_production_redis_password_here

# ────────────────────────────────────────────────────────────────
# MinIO Object Storage Configuration
# ────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=http://minio:9000
MINIO_ROOT_USER=your_minio_user_here
MINIO_ROOT_PASSWORD=your_minio_password_here

# ────────────────────────────────────────────────────────────────
# JWT Configuration
# ────────────────────────────────────────────────────────────────
# IMPORTANT: Use a strong random key (at least 256 bits for HS256)
# Generate with: openssl rand -base64 32
JWT_SECRET=your_production_jwt_secret_key_here

# ────────────────────────────────────────────────────────────────
# CORS Configuration
# ────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for production
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ────────────────────────────────────────────────────────────────
# AI Provider API Keys (Optional - set your own keys to enable AI features)
# Supported providers: OpenAI, Claude, Qwen, MiniMax
# ────────────────────────────────────────────────────────────────
AI_OPENAI_API_KEY=your-openai-api-key-here
AI_CLAUDE_API_KEY=your-claude-api-key-here
AI_QWEN_API_KEY=your-qwen-api-key-here
AI_MINIMAX_API_KEY=your-minimax-api-key-here
AI_MINIMAX_VIDEO_API_KEY=your-minimax-video-api-key-here

# Legacy non-prefixed aliases (consumed by application.yml fallbacks)
OPENAI_API_KEY=${AI_OPENAI_API_KEY}
CLAUDE_API_KEY=${AI_CLAUDE_API_KEY}
QWEN_API_KEY=${AI_QWEN_API_KEY}
MINIMAX_API_KEY=${AI_MINIMAX_API_KEY}

# ────────────────────────────────────────────────────────────────
# Aliyun TTS Configuration (Optional - for voice synthesis)
# ────────────────────────────────────────────────────────────────
ALIYUN_TTS_ACCESS_KEY=your-aliyun-access-key
ALIYUN_TTS_ACCESS_SECRET=your-aliyun-access-secret

# ────────────────────────────────────────────────────────────────
# Payment Configuration (Optional - for payment features)
# ────────────────────────────────────────────────────────────────
PAYMENT_ENABLED=false

# Alipay Configuration
ALIPAY_APP_ID=your-alipay-app-id
ALIPAY_PRIVATE_KEY=your-alipay-private-key
ALIPAY_PUBLIC_KEY=your-alipay-public-key
ALIPAY_NOTIFY_URL=https://yourdomain.com/api/payment/alipay/notify
ALIPAY_RETURN_URL=https://yourdomain.com/payment/result
ALIPAY_SANDBOX_ENABLED=false

# WeChat Pay Configuration
WECHAT_MCH_ID=your-wechat-mch-id
WECHAT_SERIAL_NO=your-wechat-serial-no
WECHAT_PRIVATE_KEY=your-wechat-private-key
WECHAT_API_V3_KEY=your-wechat-api-v3-key
WECHAT_NOTIFY_URL=https://yourdomain.com/api/payment/wechat/notify
WECHAT_APP_ID=your-wechat-app-id
