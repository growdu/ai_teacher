# Database Configuration
DATABASE_PASSWORD=ai_teacher_secure_password_2024

# Redis Configuration
REDIS_PASSWORD=ai_teacher_redis_password_2024

MINIO_ENDPOINT=http://minio:9000
MINIO_ROOT_USER=ai_teacher
MINIO_ROOT_PASSWORD=ai_teacher_minio_password_2024

# JWT Configuration
JWT_SECRET=ai_teacher_jwt_secret_key_must_be_at_least_256_bits_long_for_hs256

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://43.155.143.50,http://localhost:80,http://localhost:3000

# AI Provider API Keys (映射到 docker-compose.yml 的 AI_*_API_KEY 变量)
AI_OPENAI_API_KEY=sk-you...-key
AI_CLAUDE_API_KEY=sk-ant...-key
AI_QWEN_API_KEY=sk-you...-key
AI_MINIMAX_API_KEY=your-minimax-api-key
